
# ---------------------------------------------------------------------------
# This file is auto-generated by the Dell CoE OpenShift YAML Generator.
# Do NOT edit this file manually.
#
# Source of truth:
#   - datacenters/pde.json
#   - Jinja2 templates in templates/
#
# Rebuild Process:
#   Modify source JSON/templates → re-run generator → new YAML output.
#
# Output Cluster Information:
#   - Cluster FQDN: api.{{ cluster.name }}.{{ cluster.baseDomain }}
#   - Ingress FQDN: *.apps.{{ cluster.name }}.{{ cluster.baseDomain }}
#   - Networking Model: Dual-stack IPv4 + IPv6. VLAN {{networking.vlanId}} for machine network.
# ---------------------------------------------------------------------------
apiVersion: v1

# ---------------------------------------------------------------------------
# Base domain used for cluster, API, and ingress URLs.
# Full API URL = api.<cluster-name>.<baseDomain>
# Example: api.ctc-pde-hub-c1.corp.test.com
# ---------------------------------------------------------------------------
baseDomain: {{ cluster.baseDomain }}
metadata:
  # Cluster name; forms part of cluster FQDNs.
  name: {{ cluster.name }}

  
# ---------------------------------------------------------------------------
# COMPUTE NODES (Infra)
# These run:
#   - Ingress controllers
#   - Monitoring stack
#   - Registry
#   - Storage operators (if ODF)
#
# Replicas = {{ nodes | selectattr("role", "equalto", "infra") | list | length }} → High availability
# ---------------------------------------------------------------------------
compute:
  - name: infra
    replicas: {{ nodes | selectattr("role", "equalto", "infra") | list | length }}
    architecture: amd64
    hyperthreading: Enabled
    platform:
      none: {}


# ---------------------------------------------------------------------------
# CONTROL PLANE (Masters)
# These run:
#   - etcd
#   - API server
#   - Scheduler + Controller Manager
# Must always be odd count for etcd quorum.
# ---------------------------------------------------------------------------
controlPlane:
  name: master
  replicas: {{ nodes | selectattr("role", "equalto", "master") | list | length }}
  architecture: amd64
  hyperthreading: Enabled
  platform:
    none: {} # BareMetal platform doesn't require specific platform configuration here.

networking:
  networkType: OVNKubernetes
  
  # -------------------------
  # Pod Network
  # ------------------------- 
  clusterNetwork:
    - cidr: {{ networking.clusterNetworkIPv4 }}
      hostPrefix: {{ networking.clusterNetworkHostPrefixIPv4 }}
{%- if networking.clusterNetworkIPv6 %}
    - cidr: {{ networking.clusterNetworkIPv6 }}
      hostPrefix: {{ networking.clusterNetworkHostPrefixIPv6 }}
{%- endif %}
  
  # -------------------------
  # Machine Network
  # Networks to which hosts belong (VLAN 201)
  # Required for:
  #   - VIP allocation
  #   - Node ignition downloads
  #   - API access
  # -------------------------
  machineNetwork:
    - cidr: {{ networking.machineNetworkIPv4 }}
{%- if networking.machineNetworkIPv6 %}
    - cidr: {{ networking.machineNetworkIPv6 }}
{%- endif %}
  
  # -------------------------
  # Service Network
  # Internal Kubernetes Service CIDRs
  # -------------------------
  serviceNetwork:
    - cidr: {{ networking.serviceNetworkIPv4 }}
{%- if networking.serviceNetworkIPv6 %}
    - cidr: {{ networking.serviceNetworkIPv6 }}
{%- endif %}


# ---------------------------------------------------------------------------
# PLATFORM CONFIGURATION — Bare Metal
# Used in agent-based OpenShift deployments.
# Defines VIPs for:
#   - Kubernetes API (apiVIPs)
#   - Ingress (ingressVIPs)
#
# Dual-stack VIPs must be supplied in IPv4 + IPv6 pairs.
# ---------------------------------------------------------------------------
platform:
  baremetal:
    apiVIPs:
{%- if networking.apiVIPv4 %}
      - {{ networking.apiVIPv4 }}
{%- endif %}
{%- if networking.apiVIPv6 %}
      - {{ networking.apiVIPv6 }}
{%- endif %}

    ingressVIPs:
{%- if networking.ingressVIPv4 %}
      - {{ networking.ingressVIPv4 }}
{%- endif %}
{%- if networking.ingressVIPv6 %}
      - {{ networking.ingressVIPv6 }}
{%- endif %}


# ---------------------------------------------------------------------------
# Security Configuration
# FIPS = false → Standard crypto mode (faster)
# ---------------------------------------------------------------------------
fips: false

# ---------------------------------------------------------------------------
# Authentication: Required for cluster creation
# Provide valid Red Hat pull secret + SSH key for debugging nodes.
# ---------------------------------------------------------------------------
pullSecret: '<PULL_SECRET>'
sshKey: '<SSH_KEY>'