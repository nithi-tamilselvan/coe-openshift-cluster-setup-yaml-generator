# ------------------------------------------------------------
# OpenShift Agent-Based Installer Configuration
# Defines host networking, roles, VIP rendezvous, DNS, routes,
# NTP sources, and VLAN configurations.
# ------------------------------------------------------------

apiVersion: v1beta1
kind: AgentConfig
metadata:
  name: {{ cluster.name }}-agent-config

# This IP is used for bootstrapping / rendezvous node communication
rendezvousIP: {{ nodes[0].mgmtnetworkIPs.ipv4 }}


# ------------------------------------------------------------
# HOST DEFINITIONS
# Each host defines hardware identity (MAC), networking config,
# VLANs, IPs, DNS, and NTP sources.
# ------------------------------------------------------------
hosts:
{%- for node in nodes %}
  
  # ================================
  # {{ (node.role).upper() }} NODE {{ node.hostname }}
  # ================================
  - hostname: {{ node.hostname }}
    role: {{ node.role }}
    rootDeviceHints:
      deviceName: {{ node.rootDeviceHints.deviceName }}
      serialNumber : {{ node.rootDeviceHints.serialNumber }}
      vendor: {{ node.rootDeviceHints.vendor }}
      minSizeGigabytes : {{ node.rootDeviceHints.minSizeGigabytes }}
      wwn : {{ node.rootDeviceHints.wwn }}
      rotational : {{ node.rootDeviceHints.rotational }}
    interfaces:
      - name: eno8303   # Physical interface used for all networking
        macAddress: {{ node.mac }} # Unique hardware identifier for the node, used for network configuration and host identification.

    networkConfig:
      interfaces:

        # ---------------------------
        # Primary NIC (L2 only)
        # ---------------------------
        - name: eno8303
          type: ethernet
          state: up
          mac-address: {{ node.mac }}
{# ================= MACHINE VLAN ================= #}
{%- if networking.vlanId %}    
        # ---------------------------
        # Machine Network VLAN 201
        # Used for Control Plane traffic
        # ---------------------------
        - name: eno8303.{{ networking.vlanId }}
          type: vlan
          state: up
          mtu: {{ networking.mtu }}
          vlan:
            base-iface: eno8303
            id: {{ networking.vlanId }}
          ipv4:
            enabled: true
            dhcp: false
            address:
              - ip: {{ node.mgmtnetworkIPs.ipv4 }}
                prefix-length: {{ networking.machineNetworkIPv4.split('/')[-1] }}
{%- if node.mgmtnetworkIPs.ipv6 %}
          ipv6:
            enabled: true
            dhcp: false
            address:
              - ip: {{ node.mgmtnetworkIPs.ipv6 }}
                prefix-length: {{ networking.machineNetworkIPv6.split('/')[-1] }}
{%- endif %}
{%- endif %}
{# ================= STORAGE VLANs ================= #}
{%- if node.storageIPs %}
{%- for vlan, ip in node.storageIPs.items() %}
        # Storage VLAN {{ vlan }}
        - name: eno8303.{{ vlan }}
          type: vlan
          state: up
          mtu: {{ networking.mtu }}
          vlan:
            base-iface: eno8303
            id: {{ vlan }}
          ipv4:
            enabled: true
            dhcp: false
            address:
              - ip: {{ ip }}
                prefix-length: 23
{%- endfor %}
{%- endif %}
      
      # -----------------------------
      # DNS Servers for the host
      # -----------------------------
      dns-resolver:
        config:
          server:
{%- for dns in networking.dnsServers %}
            - {{ dns }}
{%- endfor %}
      
      # -----------------------------
      # Routing table (default routes)
      # IPv4 + IPv6 gateways
      # -----------------------------
      routes:
        config:
          - destination: 0.0.0.0/0
            # Without it, default routes (0.0.0.0/0) may install to table 0, causing VLAN routing priority issues
            table-id: 254
            next-hop-address: {{ networking.gatewayIPv4 }}
            next-hop-interface: eno8303{%- if networking.vlanId %}.{{ networking.vlanId }}{%- endif %}
{%- if networking.gatewayIPv6 %}
          - destination: ::/0
            table-id: 254
            next-hop-address: {{ networking.gatewayIPv6 }}
            next-hop-interface: eno8303{%- if networking.vlanId %}.{{ networking.vlanId }}{%- endif %}
{%- endif %}

      additionalNTPSources:
{%- for ntp in networking.ntpSources %}
        - {{ ntp }}
{%- endfor %}

{%- endfor %}